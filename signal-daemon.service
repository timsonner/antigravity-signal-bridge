[Unit]
Description=Signal CLI HTTP Daemon
After=network.target

[Service]
Type=simple
User=root
# Explicitly passing the SDKMAN Java 25 path to the Environment
Environment="PATH=/root/.sdkman/candidates/java/current/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/usr/local/bin/signal-cli --account +YOUR_PHONE_NUMBER daemon --http 0.0.0.0:8080
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
